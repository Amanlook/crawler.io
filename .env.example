# ─── Application ──────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# ─── PostgreSQL ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler_dev_password
POSTGRES_DB=crawler_io

# ─── Redis ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Proxy Configuration ─────────────────────────
BRIGHTDATA_HOST=
BRIGHTDATA_PORT=0
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# ─── Platform API Keys ───────────────────────────
YOUTUBE_API_KEY=

# ─── Celery ───────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── API ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]
